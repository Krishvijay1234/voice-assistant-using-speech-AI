      "source": [
        "def record_audio(duration=4, fs=16000):\n",
        "    print(\"Recording...\")\n",
        "    try:\n",
        "        audio = sd.rec(int(duration * fs), samplerate=fs, channels=1)\n",
        "        sd.wait()\n",
        "        print(\"Recording saved.\")\n",
        "    except sd.PortAudioError:\n",
        "        print(\"No microphone found. Creating a silent 'live.wav' file instead.\")\n",
        "        # Create a silent audio array (duration * fs samples, 1 channel, int16 dtype)\n",
        "        audio = np.zeros(int(duration * fs), dtype=np.int16).reshape(-1, 1)\n",
        "    wav.write(\"live.wav\", fs, audio)"
