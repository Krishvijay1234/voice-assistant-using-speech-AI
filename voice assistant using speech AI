        "from sklearn.metrics import classification_report\n",
        "\n",
        "# Function to create the intent column\n",
        "def create_intent(row):\n",
        "    parts = []\n",
        "    if row[\"action\"] != \"none\":\n",
        "        parts.append(row[\"action\"])\n",
        "    if row[\"object\"] != \"none\":\n",
        "        parts.append(row[\"object\"])\n",
        "    if row[\"location\"] != \"none\":\n",
        "        parts.append(row[\"location\"])\n",
        "    return \" \".join(parts)\n",
        "\n",
        "# Apply the function to create the 'intent' column in train_df and test_df\n",
        "train_df[\"intent\"] = train_df.apply(create_intent, axis=1)\n",
        "test_df[\"intent\"] = test_df.apply(create_intent, axis=1)\n",
        "\n",
        "# Train Intent Classifier(TF-IDF+Logistic Regression)\n",
        "vectorizer = TfidfVectorizer()\n",
        "X_train = vectorizer.fit_transform(train_df[\"transcription\"])\n",
        "y_train = train_df[\"intent\"]\n",
        "\n",
        "X_test = vectorizer.transform(test_df[\"transcription\"])\n",
        "y_test = test_df[\"intent\"]\n",
        "\n",
        "classifier = LogisticRegression(max_iter=1000)\n",
        "classifier.fit(X_train, y_train)\n",
